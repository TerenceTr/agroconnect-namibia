# =====================================================================
# AgroConnect Backend — Environment Configuration (EXAMPLE)
# ai-service\.env.example
# ---------------------------------------------------------------------
# FILE ROLE:
#   • Backend configuration template for local dev / Docker.
#   • DO NOT store real secrets here.
# =====================================================================

# ------------------------------
# Core Security (human auth)
# ------------------------------
SECRET_KEY=change-this-secret
JWT_SECRET=change-this-jwt-secret

# ------------------------------
# Service-to-Service Security (AI microservice)
# ------------------------------
# Shared secret between backend and ai-service
BACKEND_SERVICE_TOKEN=change-this-ai-service-token

# ------------------------------
# Runtime
# ------------------------------
FLASK_ENV=development
PORT=5000
DEBUG=true
PYTHONPATH=/app

# ------------------------------
# Database
# ------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agroconnect

# ------------------------------
# Redis (Socket.IO, queues, presence, caching)
# ------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------
# CORS / Socket.IO
# ------------------------------
CORS_ORIGINS=*

# ------------------------------
# Token Expiry (Hours)
# ------------------------------
ACCESS_TOKEN_HOURS=24
VERIFICATION_EXP_HOURS=168
RESET_EXP_HOURS=2

# ------------------------------
# Password hashing
# ------------------------------
BCRYPT_LOG_ROUNDS=12

# ------------------------------
# Email (SMTP)
# ------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
EMAIL_FROM=no-reply@agroconnect.local

# ------------------------------
# SMS
# ------------------------------
SMS_PROVIDER=console
SMS_SENDER=AgroConnect

# ------------------------------
# Feature Flags
# ------------------------------
ENABLE_SMS_QUEUE=true
ENABLE_EMAIL_QUEUE=true
ENABLE_AI_ENGINE=true

# ------------------------------
# Storage (local | s3)
# ------------------------------
STORAGE_BACKEND=local
STORAGE_BUCKET=agroconnect
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# ------------------------------
# Logging
# ------------------------------
LOG_LEVEL=DEBUG
