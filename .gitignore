# ==============================================================================
# .gitignore — AgroConnect Namibia
# ==============================================================================
# FILE ROLE:
#   Prevent sensitive data, generated files, caches, dependencies, runtime uploads,
#   archive files, temporary notes, and machine-specific files from being committed.
# ==============================================================================


# ------------------------------------------------------------------------------
# Real environment files / secrets
# ------------------------------------------------------------------------------
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
ai_service/.env
ai_service/.env.*

# Keep safe environment templates only
!.env.example
!.env.sample
!.env.template
!.env.prod.example

!backend/.env.example
!backend/.env.sample
!backend/.env.template
!backend/.env.prod.example

!frontend/.env.example
!frontend/.env.sample
!frontend/.env.template
!frontend/.env.development.example
!frontend/.env.production.example

!ai_service/.env.example
!ai_service/.env.sample
!ai_service/.env.template
!ai_service/.env.prod.example


# ------------------------------------------------------------------------------
# Uploaded/archive files
# These are often temporary project exports and should not be committed.
# ------------------------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz


# ------------------------------------------------------------------------------
# Temporary cleanup/review notes
# These are useful during refactoring but should not be committed.
# ------------------------------------------------------------------------------
CLEANUP_NOTES_*.txt
**/CLEANUP_NOTES_*.txt
SOCKETIO_RUN_NOTE.txt
**/README_overview_message_customer_shortcut.txt


# ------------------------------------------------------------------------------
# Node / frontend dependencies and logs
# ------------------------------------------------------------------------------
node_modules/
frontend/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/


# ------------------------------------------------------------------------------
# Frontend generated build outputs
# These are created by npm run build and should not be committed.
# ------------------------------------------------------------------------------
frontend/build/
frontend/dist/
build/
dist/


# ------------------------------------------------------------------------------
# Python virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/

backend/.venv/
backend/venv/
backend/env/

ai_service/.venv/
ai_service/venv/
ai_service/env/


# ------------------------------------------------------------------------------
# Python caches, compiled files, and test/tooling caches
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo

.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
pyright-report.json

*.egg-info/
.eggs/
pip-wheel-metadata/


# ------------------------------------------------------------------------------
# Flask / backend runtime folders
# ------------------------------------------------------------------------------
instance/
backend/instance/


# ------------------------------------------------------------------------------
# Backend runtime uploads
# Keep only controlled defaults and .gitkeep.
# Runtime product images and payment proofs should not be committed.
# ------------------------------------------------------------------------------
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/defaults/
!backend/uploads/defaults/**


# ------------------------------------------------------------------------------
# Local database files and database dumps
# Keep only intentional schema/seed files under database/ if needed.
# ------------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

agroconnect_db.sql
backend/agroconnect_db.sql

!database/schema.sql
!database/seed_demo.sql
!database/README.md


# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
logs/
backend/logs/
frontend/logs/
ai_service/logs/


# ------------------------------------------------------------------------------
# Docker/runtime noise
# ------------------------------------------------------------------------------
.docker/
docker-data/


# ------------------------------------------------------------------------------
# OS junk
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini


# ------------------------------------------------------------------------------
# Editor / IDE files
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*~


# ------------------------------------------------------------------------------
# Backups created during cleanup
# ------------------------------------------------------------------------------
_runtime_backup/
*.bak
*.backup
*.old