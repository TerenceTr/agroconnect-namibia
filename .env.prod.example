# ===============================================================
# Example Production Environment File
# AgroConnect Backend
# ===============================================================

# ------------------------
# FLASK / APP SETTINGS
# ------------------------
FLASK_ENV=production
SECRET_KEY=change_me_in_production_123456
JWT_SECRET=change_this_jwt_secret_value

# ------------------------
# DATABASE
# ------------------------
# Example for PostgreSQL
DATABASE_URL=postgresql://agro:agro123@postgres:5432/agroconnect

# ------------------------
# EMAIL SETTINGS
# ------------------------
MAIL_FROM=no-reply@agroconnect.na

# ------------------------
# JWT TOKEN EXPIRY
# ------------------------
ACCESS_TOKEN_HOURS=24
VERIFICATION_EXP_HOURS=168
RESET_EXP_HOURS=2

# ------------------------
# CORS
# ------------------------
CORS_ORIGINS=*

# ------------------------
# SOCKET.IO
# ------------------------
SOCKETIO_MESSAGE_QUEUE=redis://redis:6379/0
