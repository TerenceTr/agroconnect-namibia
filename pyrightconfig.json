{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.13",
  "pythonPlatform": "Windows",
  "useLibraryCodeForTypes": true,

  "reportMissingImports": "none",
  "reportMissingTypeStubs": "none",

  "venvPath": ".",
  "venv": ".venv",

  "include": ["backend"],

  "extraPaths": [
    ".",
    "./backend"
  ],

  "exclude": [
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**"
  ]
}
