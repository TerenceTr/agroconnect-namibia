# =====================================================================
# AgroConnect Backend — ENV TEMPLATE
# File: backend/.env.example
# ROLE:
#   • Example configuration
#   • Safe to commit
#   • Copy to .env for local development
# =====================================================================

# -----------------------------
# Security
# -----------------------------
SECRET_KEY=change-this-secret
JWT_SECRET=change-this-jwt-secret
BACKEND_SERVICE_TOKENS=dev-ai-token-v1

# -----------------------------
# Runtime
# -----------------------------
FLASK_ENV=development
PORT=5000
DEBUG=true

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agroconnect

# -----------------------------
# Redis (OPTIONAL)
# -----------------------------
# Leave empty unless Redis is running locally.
# If you set REDIS_URL but Redis isn't running, you may see:
#   "Cannot receive from redis..."
REDIS_URL=

# -----------------------------
# CORS
# -----------------------------
# Use comma-separated origins for production-like dev:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=*

# -----------------------------
# JWT expiry
# -----------------------------
ACCESS_TOKEN_HOURS=24
VERIFICATION_EXP_HOURS=168
RESET_EXP_HOURS=2

# -----------------------------
# Hashing
# -----------------------------
BCRYPT_LOG_ROUNDS=12

# -----------------------------
# Email
# -----------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
EMAIL_FROM=no-reply@agroconnect.local

# -----------------------------
# SMS
# -----------------------------
SMS_PROVIDER=console
SMS_SENDER=AgroConnect

# -----------------------------
# Storage (local by default)
# -----------------------------
STORAGE_BACKEND=local
STORAGE_BUCKET=agroconnect
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# -----------------------------
# AI / Research Controls
# -----------------------------
ENABLE_AI_ENGINE=true
AI_ERROR_THRESHOLD=5
AI_ERROR_WINDOW_SECONDS=60
AI_DISABLE_SECONDS=120
ENABLE_ASYNC_STOCK_ALERTS=true

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=DEBUG
