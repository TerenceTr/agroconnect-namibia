# ============================================================================
# AgroConnect Backend — ENV TEMPLATE
# File: backend/.env.example
# ROLE:
#   • Example configuration for local development
#   • Safe to commit
#   • Copy this file to backend/.env and fill in real local values
#   • Aligned with backend/config.py and current settings-driven backend
# ============================================================================

# -----------------------------
# Security
# -----------------------------
# Replace these in your real .env file.
SECRET_KEY=change-this-secret
JWT_SECRET=change-this-jwt-secret

# Optional comma-separated tokens allowed for X-Service-Token
# Example:
# BACKEND_SERVICE_TOKENS=dev-ai-token-v1,dev-worker-token-v1
BACKEND_SERVICE_TOKENS=dev-ai-token-v1

# -----------------------------
# Runtime
# -----------------------------
FLASK_ENV=development
DEBUG=true
PORT=5000
APP_VERSION=dev-local
MAINTENANCE_MODE=false

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agroconnect

# SQLAlchemy pool hardening
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
SQLALCHEMY_ECHO=false

# -----------------------------
# CORS
# -----------------------------
# Recommended for local development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------
# JWT expiry (hours)
# -----------------------------
ACCESS_TOKEN_HOURS=24
VERIFICATION_EXP_HOURS=168
RESET_EXP_HOURS=2

# -----------------------------
# Password hashing
# -----------------------------
BCRYPT_LOG_ROUNDS=12

# -----------------------------
# Email (SMTP)
# IMPORTANT:
#   For Gmail use an App Password, not your normal Gmail password.
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_character_gmail_app_password
SMTP_TLS=true

# Older compatibility flag used by backend/config.py
MAIL_USE_SSL=false

EMAIL_FROM=your_gmail_address@gmail.com

# -----------------------------
# SMS
# -----------------------------
# console = logs SMS to backend console only
SMS_PROVIDER=console
SMS_SENDER=AgroConnect

# -----------------------------
# Storage (local by default)
# -----------------------------
# local | s3
STORAGE_BACKEND=local
STORAGE_BUCKET=agroconnect
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# -----------------------------
# AI / Research Controls
# -----------------------------
ENABLE_AI_ENGINE=true
AI_ERROR_THRESHOLD=5
AI_ERROR_WINDOW_SECONDS=60
AI_DISABLE_SECONDS=120
ENABLE_ASYNC_STOCK_ALERTS=true

# -----------------------------
# Delivery / Distance Estimation
# -----------------------------
# Enable suggested delivery fee workflow
ENABLE_DELIVERY_ESTIMATOR=true

# Provider:
#   haversine = offline straight-line estimate
#   google    = driving distance (requires GOOGLE_MAPS_API_KEY)
DELIVERY_DISTANCE_PROVIDER=haversine
GOOGLE_MAPS_API_KEY=

# Fee model (N$)
DELIVERY_BASE_FEE=25
DELIVERY_PER_KM=4.5
DELIVERY_FREE_KM=0
DELIVERY_MIN_FEE=15
DELIVERY_MAX_FEE=200

# Cache TTL for distance lookups (seconds)
DELIVERY_DISTANCE_CACHE_TTL_SECONDS=86400

# -----------------------------
# Platform / policy defaults
# These are startup defaults and may later be overridden by persisted
# admin system settings.
# -----------------------------
READ_ONLY_MODE=false
CACHE_TTL=300
DEFAULT_REPORT_DAYS=90
REPORT_PREVIEW_ROWS=25
MAINTENANCE_MESSAGE=Scheduled maintenance in progress. Please try again shortly.

# -----------------------------
# Marketplace defaults
# -----------------------------
MARKETPLACE_CURRENCY_CODE=NAD
VAT_PERCENT=15
LOW_STOCK_THRESHOLD=5
FEATURED_PRODUCTS_LIMIT=8
ALLOW_RATINGS=true
ALLOW_PRODUCT_LIKES=true

# -----------------------------
# Checkout defaults
# -----------------------------
ALLOW_DELIVERY=true
ALLOW_PICKUP=true
AUTO_CANCEL_UNPAID_HOURS=24
DEFAULT_DELIVERY_FEE=30
FREE_DELIVERY_THRESHOLD=500
MAX_CART_ITEMS=50
MAX_ORDER_LINES_PER_CHECKOUT=20

# -----------------------------
# Payment defaults
# -----------------------------
EFT_ENABLED=true
CASH_ON_DELIVERY_ENABLED=false
MANUAL_REVIEW_ENABLED=true
PROOF_OF_PAYMENT_REQUIRED_FOR_EFT=true
MAX_PAYMENT_PROOF_MB=5
MANUAL_REVIEW_THRESHOLD_NAD=1500

# -----------------------------
# Communications defaults
# -----------------------------
IN_APP_NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=true
BROADCAST_EMAIL_ENABLED=true
BROADCAST_SMS_ENABLED=true

# -----------------------------
# Moderation defaults
# -----------------------------
PRODUCT_REVIEW_SLA_HOURS=48
AUTO_PUBLISH_APPROVED_PRODUCTS=true
REQUIRE_REJECTION_REASON=true
FLAG_DUPLICATE_PRODUCTS=true

# -----------------------------
# Analytics defaults
# -----------------------------
AI_INSIGHTS_ENABLED=true
LOW_STOCK_ALERTS_ENABLED=true
SEARCH_ANALYTICS_ENABLED=true
MARKET_TRENDS_ENABLED=true
RANKING_WIDGETS_ENABLED=true

# -----------------------------
# Search defaults
# -----------------------------
AUTOCOMPLETE_ENABLED=true
TRENDING_SEARCHES_ENABLED=true
SEARCH_HISTORY_RETENTION_DAYS=90
SEARCH_SUGGESTIONS_LIMIT=8

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=DEBUG